            0.5, -0.866025388, -5.86211681e-05,
            -4.70876694e-05, 4.05311584e-05, -1,
            0.866025329, 0.5, -2.05039978e-05
        )
        safeTeleport(target)
    end)

    local Slaps = Window:NewSection("Slaps")
    Slaps:CreateButton("Get Lava Slap", function()
        local char = getCharacter()
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        local humanoidNow = char:FindFirstChildOfClass("Humanoid")
        if humanoidNow then
            pcall(function()
                humanoidNow.Sit = false
                humanoidNow.PlatformStand = false
            end)
        end
        local targetCFrame = CFrame.new(
            -679.016418, -333.809723, 1005.36572,
            0.0175017118, 0, -0.999846935,
            0, 1, 0,
            0.999846935, 0, 0.0175017118
        )
        local original = hrp.CFrame
        safeTeleport(targetCFrame)
        task.wait(3)
        safeTeleport(original)
        StarterGui:SetCore("SendNotification", {Title = "Lua Land Team", Text = "We will return you to your current workspace", Duration = 5})
    end)

    local antiEnabled = false
    local antiChildConn = nil
    local antiCharAddedConn = nil

    Slaps:CreateButton("Anti-Slap", function()
        antiEnabled = not antiEnabled
        if antiEnabled then
            local localplr = game.Players.LocalPlayer
            local function dobv(v,char)
                local undo = false
                if antiEnabled then
                    if v:IsA("BodyAngularVelocity") then
                        undo = true
                        pcall(function() v:Destroy() end)
                    elseif v:IsA("BodyGyro") and v.MaxTorque ~= Vector3.new(8999999488, 8999999488, 8999999488) and v.D ~= 500 and v.D ~= 50 and v.P ~= 90000 then
                        undo = true
                        pcall(function() v:Destroy() end)
                    elseif v:IsA("BodyVelocity") and v.MaxForce ~= Vector3.new(8999999488, 8999999488, 8999999488) and v.Velocity ~= Vector3.new(0,0,0) then
                        undo = true
                        pcall(function() v:Destroy() end)
                    elseif v:IsA("BasePart") then
                        pcall(function()
                            v.ChildAdded:Connect(function(v2)
                                dobv(v2,char)
                            end)
                        end)
                    end
                    if undo and char and char:FindFirstChild("Humanoid") then
                        pcall(function()
                            char.Humanoid.Sit = false
                            char.Humanoid.PlatformStand = false
                        end)
                    end
                end
            end
            local function dc(c)
                for _,v in pairs(c:GetChildren()) do
                    dobv(v,c)
                end
                antiChildConn = c.ChildAdded:Connect(function(v)
                    dobv(v,c)
                end)
            end
            if localplr.Character then
                dc(localplr.Character)
            end
            antiCharAddedConn = localplr.CharacterAdded:Connect(dc)
        else
            if antiChildConn then
                pcall(function() antiChildConn:Disconnect() end)
                antiChildConn = nil
            end
            if antiCharAddedConn then
                pcall(function() antiCharAddedConn:Disconnect() end)
                antiCharAddedConn = nil
            end
        end
    end)

    local Killbrick = Window:NewSection("Killbrick Mod")
    Killbrick:CreateButton("Destroy", function()
        local function isKillBrick(part)
            if part:IsA("BasePart") then
                local color = part.Color
                local name = part.Name:lower()
                return color == Color3.fromRGB(255, 0, 0) or name:find("kill") or name:find("lava") or name:find("death")
            end
            return false
        end
        for _, part in ipairs(workspace:GetDescendants()) do
            if isKillBrick(part) then
                pcall(function() part:Destroy() end)
            end
        end
    end)

    local Credits = Window:NewSection("Credits")
    Credits:CreateButton("By: Lua Land TeamÂ®", function()
