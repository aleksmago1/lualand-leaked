    end)

    local AutoWins = Window:NewSection("AutoWins")
    AutoWins:CreateButton("Instant Win", function()
        local running = true
        StarterGui:SetCore("SendNotification", {Title = "Lua Land", Text = "Reset Character To Stop!", Duration = 5})
        spawn(function()
            local locations = {
                CFrame.new(391.750031, -299.521271, 1552.99988),
                CFrame.new(-79.1855469, -299.671387, 1592.67651),
                CFrame.new(114.349243, -286.670135, 974.583374),
                CFrame.new(-756.016785, -244.671555, 1275.0177)
            }
            local index = 1
            while running do
                local char = getCharacter()
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                local humanoidNow = char and char:FindFirstChildOfClass("Humanoid")
                if not hrp or not hrp.Parent then
                    running = false
                    break
                end
                if humanoidNow then
                    pcall(function()
                        humanoidNow.Sit = false
                        humanoidNow.PlatformStand = false
                    end)
                end
                pcall(function() hrp.Velocity = Vector3.new(0,60,0) end)
                safeTeleport(locations[index])
                index = index % #locations + 1
                task.wait(0.6)
            end
        end)
        player.CharacterRemoving:Connect(function() running = false end)
    end)

    local Secret = Window:NewSection("Secret")
    Secret:CreateButton("Secret 1", function()
        local target = CFrame.new(
            -779.500061, -242.251541, 1365.21643,
            0, 0, -1,
            0, 1, 0,
            1, 0, 0
        )
        safeTeleport(target)
    end)

    Secret:CreateButton("Secret 2", function()
