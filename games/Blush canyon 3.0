    end)
    Credits:CreateButton("Join Discord", function()
        safeSetClipboard("discord.gg/EHhKBYhaRd")
        StarterGui:SetCore("SendNotification", {Title = "Lua Land", Text = "COPIED!", Duration = 3})
    end)
end

if Library then
    createWithWizard(Library)
else
    StarterGui:SetCore("SendNotification", {Title = "Error", Text = "Wizard UI Library failed to load, contact the owner or re-execute the script.", Duration = 4})
end
