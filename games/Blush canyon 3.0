task.wait(3)

local function safeLoadWizard()
    local url = "https://raw.githubusercontent.com/bloodball/-back-ups-for-libs/main/wizard"
    local ok, lib = pcall(function()
        return loadstring(game:HttpGet(url))()
    end)
    if ok and lib then
        return lib
    end
    return nil
end

local Library = safeLoadWizard()
local Players = game:GetService("Players")
local StarterGui = game:GetService("StarterGui")
local RunService = game:GetService("RunService")
local player = Players.LocalPlayer

local function getCharacter()
    if not player then return nil end
    local char = player.Character or player.CharacterAdded:Wait()
    return char
end

local function getHRP()
    local char = getCharacter()
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart") or char:WaitForChild("HumanoidRootPart")
end

local function getHumanoid()
    local char = getCharacter()
    if not char then return nil end
    return char:FindFirstChildOfClass("Humanoid") or char:WaitForChild("Humanoid")
end

local function safeSetClipboard(text)
    pcall(function()
        setclipboard(text)
    end)
end

local function setCharacterCollision(character, canCollide)
    for _, part in ipairs(character:GetDescendants()) do
        if part:IsA("BasePart") then
            pcall(function() part.CanCollide = canCollide end)
        end
    end
end

local function clearVelocities(character)
    for _, part in ipairs(character:GetDescendants()) do
        if part:IsA("BasePart") then
            pcall(function()
                part.Velocity = Vector3.new(0,0,0)
                if pcall(function() return part.AssemblyLinearVelocity end) then
                    part.AssemblyLinearVelocity = Vector3.new(0,0,0)
                end
                if pcall(function() return part.AssemblyAngularVelocity end) then
                    part.AssemblyAngularVelocity = Vector3.new(0,0,0)
                end
            end)
        end
    end
end

local function safeTeleport(targetCFrame)
    local char = getCharacter()
    if not char then return false end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not hrp then return false end
    if humanoid then
        pcall(function()
            humanoid.Sit = false
            humanoid.PlatformStand = false
        end)
    end
    pcall(function() char.PrimaryPart = hrp end)
    pcall(function() for _, part in ipairs(char:GetDescendants()) do if part:IsA("BasePart") then part.Anchored = false end end end)
    setCharacterCollision(char, false)
    pcall(function() hrp.Velocity = Vector3.new(0,0,0) end)
    pcall(function() hrp.CFrame = targetCFrame + Vector3.new(0,6,0) end)
    clearVelocities(char)
    task.wait(0.08)
    pcall(function() hrp.Velocity = Vector3.new(0,0,0) end)
    setCharacterCollision(char, true)
    if humanoid then
        pcall(function()
            humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
            humanoid.PlatformStand = false
            humanoid.Sit = false
        end)
    end
    task.wait(0.06)
    pcall(function() hrp.Velocity = Vector3.new(0,0,0) end)
    return true
end

